{
	"compilerOptions": {
		"esModuleInterop": true,
		"jsx": "react",
		"lib": [
			"DOM",
			"ES2020"
		],
		"module": "ES2020",
		"moduleResolution": "node",
		"noEmit": true,
		"paths": {
			"@liferay/frontend-data-set-web/api": [
				"./node_modules/@liferay/js-api/data-set"
			]
		},
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020"
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx"
	]
}